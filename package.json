{
  "name": "murphy-desktop",
  "productName": "Murphy Desktop",
  "version": "0.6.0",
  "description": "Desktop app for murphy-cloud.com — the Murphy family cloud",
  "main": "src/main.js",
  "desktopName": "murphy-desktop",
  "author": "Cal Malagon",
  "license": "MIT",
  "repository": "github:cmalagon96/murphy-desktop",
  "scripts": {
    "start": "electron .",
    "smoke": "electron scripts/smoke.js",
    "dist:linux": "npm run build:shell && electron-builder --linux",
    "dist:win": "npm run build:shell && electron-builder --win",
    "dist:mac": "npm run build:shell && electron-builder --mac",
    "build:shell": "vite build --config shell/vite.config.mjs shell",
    "dev:shell": "vite --config shell/vite.config.mjs shell"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "build": {
    "appId": "com.murphycloud.desktop",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "productName": "Murphy Desktop",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "shell/dist/**/*",
      "build/icon.png",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network",
      "icon": "build/icon.png",
      "syncDesktopName": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.social-networking"
    }
  },
  "devDependencies": {
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.23.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3"
  }
}
